<?xml version="1.0" encoding="UTF-8"?>
<!--
  IT Operations Portal — IIS configuration
  Drop this whole folder into an IIS site (or virtual directory) and browse to it.
  Requires the IIS "URL Rewrite" module only if you enable the SPA fallback rule
  below; everything else uses built-in IIS features.
-->
<configuration>
  <system.webServer>

    <!-- Serve index.html when the folder root is requested -->
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <!-- Correct MIME types (index.html is fully self-contained, but these
         keep things correct if you later split assets back out) -->
    <staticContent>
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <!-- Do not cache the HTML shell so portal updates show up immediately -->
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>

    <!-- Gzip/brotli the (large) self-contained HTML on the wire -->
    <httpCompression>
      <dynamicTypes>
        <add mimeType="text/html" enabled="true" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="text/html" enabled="true" />
      </staticTypes>
    </httpCompression>
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- Basic security hardening headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
